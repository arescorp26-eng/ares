# ===========================================================
#  ARES — Variables de Entorno
#  Copia este archivo como .env y completa con tus valores.
# ===========================================================

# --- Base de datos MySQL (Railway provee esta URL automáticamente) ---
DATABASE_URL="mysql://USER:PASSWORD@HOST:PORT/DATABASE"

# --- OpenRouter (IA para generación de quizzes y análisis de PDFs) ---
# Obtén tu key en: https://openrouter.ai/keys
OPENROUTER_API_KEY="sk-or-v1-..."
OPENROUTER_MODEL="anthropic/claude-3-haiku"

# --- Auth (JWT secret — genera uno random con: openssl rand -base64 32) ---
JWT_SECRET="tu-secreto-super-seguro-aqui"

# --- App URL (Railway la configura automáticamente como RAILWAY_PUBLIC_DOMAIN) ---
# En Railway no necesitas esta variable, el dominio se genera solo.
# NEXT_PUBLIC_APP_URL="https://tu-dominio.railway.app"
